<Window x:Class="MakeobjControllerLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MakeobjControllerLite"
        mc:Ignorable="d"
        Title="Ahozura Makeobj Controller Lite" Height="450" Width="300" SizeToContent="WidthAndHeight" ResizeMode="CanMinimize" Icon="ahozura.ico">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+O" Command="local:MyCommands.openProject"/>
        <KeyBinding Gesture="Ctrl+S" Command="local:MyCommands.saveProject"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="421" />
        </Grid.RowDefinitions>
        <Menu Margin="0,0,0,2" Background="#FFFFFF">
            <MenuItem Header="プロジェクト(_P)">
                <MenuItem Header="開く(_O)" Click="openProject" InputGestureText="Ctrl+O"/>
                <Separator />
                <MenuItem Header="上書き保存(_S)" Click="saveProject" InputGestureText="Ctrl+S" />
                <MenuItem Header="名前を付けて保存" Click="createProject" />
                <Separator />
                <MenuItem Header="datファイルの場所を開く(_D)" Click="openDatDirectory" />
                <MenuItem Header="プロジェクトファイルの場所を開く" Click="openProjectDirectory" />
                <Separator />
                <MenuItem Header="プロジェクトを閉じる(_C)" Click="clearProject" />
                <MenuItem Header="アプリを終了(_X)" Click="closeWindow" />
            </MenuItem>
            <MenuItem Header="オプション(_O)">
                <MenuItem Header="設定(_S)" Click="OnSettingsMenuItemClick" />
                <!--
                <Separator />
                <MenuItem Header="*.ahpファイルを関連付けする" Click="setExtention" />
                <MenuItem Header="*.ahpファイルの関連付けを解除" Click="setExtention" />
                -->
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="説明書" Click="OnReadMeMenuItemClick" />
                <MenuItem Header="作者Twitter" Click="OnTwitterMenuItemClick"/>
                <MenuItem Header="公式サイト" Click="OnOfficialSiteMenuItemClick"/>
                <Separator></Separator>
                <MenuItem Header="バージョン情報" Click="OnVersionInfoMenuItemClick"/>
            </MenuItem>
        </Menu>
        <TabControl HorizontalAlignment="Left" Height="363" VerticalAlignment="Top" Width="292" Margin="0,26,0,0">
            <TabItem Header="pak">
                <Grid Background="#FFFFFFFF" RenderTransformOrigin="0.311,0.501" PreviewDragOver="filepath_PreviewDragOver" Drop="filepath_Drop" AllowDrop="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="pakファイル名 (任意)" HorizontalAlignment="Left" Height="77" Margin="10,171,0,0" VerticalAlignment="Top" Width="266"/>
                    <GroupBox Header="datファイル" HorizontalAlignment="Left" Height="77" Margin="10,87,0,0" VerticalAlignment="Top" Width="266"/>
                    <GroupBox Header="pakタイプ" HorizontalAlignment="Left" Height="77" Margin="10,4,0,0" VerticalAlignment="Top" Width="266"/>
                    <ComboBox x:Name="paktype" HorizontalAlignment="Left" Margin="22,37,0,0" VerticalAlignment="Top" Width="135" SelectionChanged="ComboBox_SelectionChanged" ItemsSource="{Binding PakTypes}" SelectedValuePath="Key" DisplayMemberPath="Value"/>
                    <TextBox x:Name="paktype_else" InputMethod.IsInputMethodEnabled="False" HorizontalAlignment="Left" Height="23" Margin="171,36,0,0" VerticalAlignment="Top" Width="94" IsEnabled="False" TextChanged="paktype_else_TextChanged"/>
                    <TextBox x:Name="filepath" HorizontalAlignment="Left" Height="23" Margin="22,121,0,0" VerticalAlignment="Top" Width="175" TextChanged="filepath_TextChanged" AllowDrop="True"/>
                    <Button Content="参照" HorizontalAlignment="Left" Height="25" Margin="202,120,0,0" VerticalAlignment="Top" Width="63" Click="OnDatFileSelectButtonClick" RenderTransformOrigin="-0.032,0.56"/>
                    <TextBox x:Name="pakFileName" HorizontalAlignment="Left" Height="23" Margin="22,205,0,0" VerticalAlignment="Top" Width="209" AllowDrop="False" TextChanged="pakname_TextChanged"/>
                    <Label Content=".pak" HorizontalAlignment="Left" Margin="231,202,0,0" VerticalAlignment="Top" Width="45" RenderTransformOrigin="-0.056,0.449"/>
                    <Button Content="pak作成" HorizontalAlignment="Left" Height="65" Margin="68,260,0,0" VerticalAlignment="Top" Width="150" Click="OnExecutePakButtonClick"/>

                </Grid>
            </TabItem>
            <TabItem Header="merge">
                <Grid Background="#FFFFFFFF" Margin="0,-1,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="ListBox1" HorizontalAlignment="Left" Height="167" Margin="10,33,0,0" VerticalAlignment="Top" Width="186" AllowDrop="True" SelectionChanged="ListBox_SelectionChanged" DragEnter="ListBox_DragEnter" Drop="ListBox_Drop" SelectionMode="Extended">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="選択ファイルをリストから消去(_R)" Click="ListBox_File_Clear"/>
                                <MenuItem Header="リストを全消去(_C)" Click="ListBox_Clear"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                    <Button Content="ファイルクリア" HorizontalAlignment="Left" Margin="201,33,0,0" VerticalAlignment="Top" Width="75" RenderTransformOrigin="0.507,1.65" Click="ListBox_File_Clear"/>
                    <Button Content="リストをクリア" HorizontalAlignment="Left" Margin="201,62,0,0" VerticalAlignment="Top" Width="75" RenderTransformOrigin="0.507,1.65" Click="ListBox_Clear"/>
                    <GroupBox Header="pakファイル名" HorizontalAlignment="Left" Height="77" Margin="10,203,0,0" VerticalAlignment="Top" Width="266"/>
                    <TextBox x:Name="pakFileName_merge" HorizontalAlignment="Left" Height="23" Margin="22,237,0,0" VerticalAlignment="Top" Width="209"/>
                    <Label Content=".pak" HorizontalAlignment="Left" Margin="231,234,0,0" VerticalAlignment="Top" Width="45" RenderTransformOrigin="-0.056,0.449"/>
                    <Label Content="pakファイルをここにドラッグ&amp;ドロップ" HorizontalAlignment="Left" Margin="10,7,0,0" VerticalAlignment="Top" Width="178"/>
                    <Button Content="pak結合" HorizontalAlignment="Left" Height="36" Margin="68,290,0,0" VerticalAlignment="Top" Width="150" Click="OnMergePakButtonClick"/>
                </Grid>
            </TabItem>
            <TabItem Header="extract">
                <Grid Background="#FFFFFF">
                    <GroupBox Header="pakファイル" HorizontalAlignment="Left" Height="77" Margin="10,69,0,0" VerticalAlignment="Top" Width="266"/>
                    <TextBox x:Name="pakFileToExtract" HorizontalAlignment="Left" Height="23" Margin="22,103,0,0" VerticalAlignment="Top" Width="175" TextChanged="pakFileToExtract_TextChanged" PreviewDragOver="pakFileToExtract_PreviewDragOver" Drop="pakFileToExtract_Drop"/>
                    <Button Content="参照" HorizontalAlignment="Left" Height="25" Margin="202,102,0,0" VerticalAlignment="Top" Width="63" Click="OnExtractPakFileSelectButtonClick" RenderTransformOrigin="-0.032,0.56"/>
                    <Button Content="pak分離" HorizontalAlignment="Left" Height="65" Margin="68,260,0,0" VerticalAlignment="Top" Width="150" Click="OnExtractPakButtonClick"/>
                </Grid>
            </TabItem>
        </TabControl>
        <StatusBar HorizontalAlignment="Left" Height="30" Margin="0,389,0,0" VerticalAlignment="Top" Width="292">
            <Label x:Name="status" Content="準備完了"/>
        </StatusBar>

    </Grid>
</Window>
